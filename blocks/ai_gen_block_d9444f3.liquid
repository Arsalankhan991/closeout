{% doc %}
  @prompt
    make a floating box with this on every page" <div class="xbfsbu-block" data-id="d25ff6f3bf8f497c86449647abb912a3"></div> ", where is the progress bar add in it
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-floating-box-{{ ai_gen_id }} {
    position: fixed;
    bottom: {{ block.settings.bottom_position }}px;
    {% if block.settings.horizontal_position == 'left' %}
      left: {{ block.settings.side_offset }}px;
    {% else %}
      right: {{ block.settings.side_offset }}px;
    {% endif %}
    z-index: {{ block.settings.z_index }};
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    width: {{ block.settings.box_width }}px;
    max-width: calc(100vw - 40px);
    display: block;
  }

  .ai-floating-box-content-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.progress_spacing }}px;
  }

  .ai-progress-bar-container-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.progress_height }}px;
    background-color: {{ block.settings.progress_bg_color }};
    border-radius: {{ block.settings.progress_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-progress-bar-fill-{{ ai_gen_id }} {
    height: 100%;
    background-color: {{ block.settings.progress_fill_color }};
    border-radius: {{ block.settings.progress_border_radius }}px;
    transition: width 0.3s ease;
    width: 0%;
  }

  .ai-progress-text-{{ ai_gen_id }} {
    margin-top: {{ block.settings.text_spacing }}px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-floating-box-{{ ai_gen_id }} {
      bottom: {{ block.settings.mobile_bottom_position }}px;
      {% if block.settings.horizontal_position == 'left' %}
        left: {{ block.settings.mobile_side_offset }}px;
      {% else %}
        right: {{ block.settings.mobile_side_offset }}px;
      {% endif %}
      width: {{ block.settings.mobile_box_width }}px;
    }
  }
{% endstyle %}

<floating-box-{{ ai_gen_id }} class="ai-floating-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-floating-box-content-{{ ai_gen_id }}">
    <div class="xbfsbu-block" data-id="d25ff6f3bf8f497c86449647abb912a3"></div>
  </div>
  
  {% if block.settings.show_progress_bar %}
    <div class="ai-progress-bar-container-{{ ai_gen_id }}">
      <div class="ai-progress-bar-fill-{{ ai_gen_id }}" data-progress="{{ block.settings.progress_value }}"></div>
    </div>
    
    {% if block.settings.show_progress_text %}
      <div class="ai-progress-text-{{ ai_gen_id }}">
        {{ block.settings.progress_text }}
      </div>
    {% endif %}
  {% endif %}
</floating-box-{{ ai_gen_id }}>

<script>
  (function() {
    class FloatingBox{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
        this.initProgressBar();
      }

      initProgressBar() {
        const progressBar = this.querySelector('.ai-progress-bar-fill-{{ ai_gen_id }}');
        if (progressBar) {
          const targetProgress = parseInt(progressBar.getAttribute('data-progress')) || 0;
          setTimeout(() => {
            progressBar.style.width = targetProgress + '%';
          }, 100);
        }
      }
    }

    customElements.define('floating-box-{{ ai_gen_id }}', FloatingBox{{ ai_gen_id }});
  })();
</script>

